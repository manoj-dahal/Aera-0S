{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist-electron"
  },
  "include": ["core", "agents", "api", "apps", "desktop", "voice", "vision", "memory", "knowledge", "skills", "plugins", "electron"]
}
